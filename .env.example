# Environment Variables for Grocera
# Copy this to .env and fill in your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
FLASK_ENV=development
DEBUG=True

# Database Configuration (MySQL)
DATABASE_URL=mysql+pymysql://root:@localhost/grocera_db
# For production with password: mysql+pymysql://username:password@host:port/database

# AI API Keys
GROK_API_KEY=your-grok-api-key-here
# Get your Grok API key from: https://console.x.ai/

# Application Settings
ITEMS_PER_PAGE=20
STOCK_ALERT_THRESHOLD=5
EXPIRY_ALERT_DAYS=7
MAX_CONTENT_LENGTH=16777216

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Additional API Keys (Optional)
OPENAI_API_KEY=your-openai-api-key-here
